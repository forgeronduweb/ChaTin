{
  "expo": {
    "name": "ChaTin",
    "slug": "mon-app-android",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/launcher.png",
    "scheme": "monappandroid",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A1A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.monappandroid"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A1A1A",
          "image": "./assets/images/flower_only_1024.png",
          "imageWidth": 160
        }
      ],
      "expo-secure-store",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0dde2580-f454-4ff0-8570-20cbb68f3ffe"
      }
    }
  }
}
