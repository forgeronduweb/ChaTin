# Postgres connection string (Supabase "Transaction pooler" URI works well here).
DATABASE_URL=

# Gemini is used first if set; otherwise falls back to Groq, then offline mock replies.
GEMINI_API_KEY=
GROQ_API_KEY=
PORT=3001

# From Google Cloud Console > APIs & Services > Credentials
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
